{
  "manifest_version": 3,
  "name": "Tab-Ban Board",
  "version": "1.0.0",
  "description": "Kanban for your tabs. New tab page that lays out your open tabs as a board with one column per root domain.",
  "permissions": ["tabs", "activeTab", "favicon"],
  "chrome_url_overrides": { "newtab": "index.html" },
  "background": { "service_worker": "background.js" },
  "action": {
    "default_title": "Tab-Ban Board",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
